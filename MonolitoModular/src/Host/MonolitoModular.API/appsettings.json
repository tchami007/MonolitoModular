{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Activación de módulos por configuración.
  // En cada cliente, este archivo puede diferir — solo los módulos habilitados
  // son registrados en DI y sus controllers son descubiertos por el host.
  "Modules": {
    "Clientes": true,
    "Creditos": true,
    "CajaDeAhorro": true
  }
}
